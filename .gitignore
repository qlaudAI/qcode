# Build outputs
node_modules
dist
.DS_Store
*.log

# Rust / Tauri
src-tauri/target
src-tauri/Cargo.lock
src-tauri/gen
src-tauri/WixTools

# TypeScript incremental cache
tsconfig.tsbuildinfo
*.tsbuildinfo

# Editor / OS
.idea
.vscode/*
!.vscode/extensions.json
.env
.env.local
.env*.local

# Tauri signing
*.pem
*.key

# Tauri sidecar binaries (downloaded per-platform in CI)
src-tauri/binaries/bun-*
src-tauri/binaries/rg-*

# Bundled claude code runtime — installed per-platform in CI via bun.
# Only the package.json with deps is checked in; node_modules + lockfile
# get recreated on every build.
src-tauri/resources/runtime/node_modules/
src-tauri/resources/runtime/bun.lock
src-tauri/resources/runtime/package-lock.json
src-tauri/resources/runtime/pnpm-lock.yaml
